<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="230.0" prefWidth="316.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.LoginController">
   <children>
      <Label layoutX="132.0" layoutY="31.0" text="Login">
         <font>
            <Font size="14.0" />
         </font></Label>
      <TextField fx:id="usernameField" layoutX="73.0" layoutY="70.0" promptText="Username" AnchorPane.bottomAnchor="135.0" AnchorPane.topAnchor="70.0" />
      <PasswordField fx:id="passwordField" layoutX="73.0" layoutY="103.0" promptText="Password" AnchorPane.topAnchor="110.0" />
      <Button alignment="CENTER" layoutX="124.0" layoutY="152.0" mnemonicParsing="false" onAction="#login" onKeyPressed="#login" text="Login" textAlignment="CENTER" />
      <Button fx:id="linkButton" layoutX="21.0" layoutY="191.0" mnemonicParsing="false" onAction="#goToSignUp" styleClass="link-button" stylesheets="@login.css" text="Nouveau? Créer un compte" />
   </children>
</AnchorPane>
